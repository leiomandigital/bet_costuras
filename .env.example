VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ------------------------------------------------------------------
# As variáveis abaixo são usadas pela Edge Function
# supabase/functions/upload-foto-pedido, que encaminha a foto para um
# webhook do n8n (o n8n autentica no Google Drive via OAuth de conta de
# usuário real, evitando a limitação de Service Accounts sem cota de
# armazenamento em Drives pessoais). Elas NUNCA devem ser lidas pelo
# frontend nem colocadas no .env deste projeto Vite — servem apenas de
# referência. Configure-as como secrets da function no painel da Supabase
# (Edge Functions -> Secrets) ou via CLI:
#
#   supabase secrets set N8N_UPLOAD_WEBHOOK_URL=...
#   supabase secrets set N8N_UPLOAD_WEBHOOK_AUTH_VALUE=...
#
# N8N_UPLOAD_WEBHOOK_URL=
# N8N_UPLOAD_WEBHOOK_AUTH_VALUE=
